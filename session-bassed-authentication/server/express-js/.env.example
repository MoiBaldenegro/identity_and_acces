# Database
DATABASE_URL="postgresql://authuser:authpass123@localhost:53466/authdb?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Session
SESSION_SECRET="cambia-esto-por-un-secreto-de-64-caracteres-generado-con-openssl-rand"
SESSION_COOKIE_NAME="__Host-session"
SESSION_TTL=86400                  # 24 horas

# Security
NODE_ENV=development
PORT=4000

# Rate limiting
LOGIN_RATE_LIMIT=5                 # intentos por IP
LOGIN_RATE_WINDOW=900000           # 15 minutos

